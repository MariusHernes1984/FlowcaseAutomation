# Flowcase Web backend — local development secrets template.
# Copy to .env and fill in before running docker compose.

ENVIRONMENT=dev

# ---- Admin bootstrap (first-boot only) ----
ADMIN_EMAIL=admin@atea.no
ADMIN_PASSWORD=change-me-on-first-login

# ---- JWT ----
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-a-long-random-string

# ---- Cosmos DB ----
# Local emulator default; in Azure set via Container App secret
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_KEY=
COSMOS_DATABASE=flowcase

# ---- Azure OpenAI / Foundry ----
AZURE_OPENAI_ENDPOINT=https://<your-foundry>.openai.azure.com
AZURE_OPENAI_API_KEY=
DEFAULT_LLM_DEPLOYMENT=gpt-4.1

# ---- Flowcase MCP (streamable HTTP) ----
MCP_URL=https://ca-flowcasemcp-dev.<hash>.norwayeast.azurecontainerapps.io/mcp
MCP_API_KEY=
