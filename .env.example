# Flowcase API credentials
# Obtain a subscription key from Atea ServiceHub (https://servicehub.atea.com/).
FLOWCASE_API_KEY=your-subscription-key-here

# Atea ServiceHub runs on Azure API Management, so the subscription key is
# typically sent in the Ocp-Apim-Subscription-Key header. Override here if
# the proxy expects a different scheme (e.g. Authorization: Bearer).
FLOWCASE_API_KEY_HEADER=Ocp-Apim-Subscription-Key

# Base URL for the Flowcase proxy.
FLOWCASE_BASE_URL=https://servicehub.atea.com/flowcase

# Preferred language for multilingual fields in CV responses.
# Values seen in the API: no, se, dk, int (international/English).
FLOWCASE_DEFAULT_LANGUAGE=no

# Default country code for user searches. When flowcase_search_users is called
# without explicit office_ids or country_codes, all offices in this country
# are used. Available codes: no, se, dk, fi, lv.
FLOWCASE_DEFAULT_COUNTRY=no
